      "564234162": {
        "spirit_name": "析沐",
        "nickname": "-析沐",
        "intro": "全馆最帅的妖。御灵系是火，技能为焚蚀，生灵系技能为异变。会馆的一切（规模、规矩、氛围）的奠基者。析沐是亲力亲为的实干家，整个会馆的一切都是析沐一手经营的。性格超级好，为妖和谐，中二自称为妖王，大家也都非常给面子。本体为形似树妖的妖兽，但还是习惯认为自己就是树妖。",
        "identity": "core_member",
        "register_time": 1771810912
      }
    }
