  "1145912829": {
    "qq": "1145912829",
    "spirit_name": "大小姐",
    "global_identity": "core_member",
    "registered_groups": [
      564234162
    ],
    "primary_group": 564234162,
    "private_bind_group": 564234162,
    "sharing_config": null,
    "global_profile": {
      "register_time": 1771819566,
      "status": "active",
      "last_active": 1775410223,
      "public_visible": true,
      "oc_details": {},
      "web_synced": false,
      "web_profile_url": ""
    },
    "group_profiles": {
      "564234162": {
        "spirit_name": "大小姐",
        "nickname": "本人太帅昵称无法显示",
        "intro": "一只来自神秘海域的特殊种群的猫鲨，在混沌时期修炼成孩童模样（不过还保留着猫耳朵和鲨鱼尾）后来遇到吉熙大人把我带回到了晋宁会馆，并培养拥有了少女模样和能力觉醒。在人类社会遇到了两个叫苒秋和鲤鱼的人类，并开始接受人类科技，乐在其中，是重度科技产品的依赖者（因为经常被投喂人类猫条-魔芋爽和果冻所以超级爱吃）\n能力觉醒方式:很久很久以前女娲后人因厌倦了鱼的结构和猫的结构设计，一怒之下意外造出了一个新物种叫猫鲨，吉熙大人不仅没有感到诧异还找来了析沐大人教导。在1020岁那年终于在一个风雨交加的夜晚掌握了水系属性（能力特质派）\n性格底色:古灵精怪，喜欢与小妖们互动 做有趣的事 偶尔精力不足摆烂 认为人类很有趣，是值得守护的伙伴\n日常爱好:晒太阳 与苒秋享受现代娱乐 吃猫条（吸收灵气）观察市井生活 \n在会馆的身份为执行者并为会馆决策组一员\n对自己出身和种族的神秘感到困惑 并被吉熙大人调侃为垃圾桶里捡来的。\n标志性特征:有独特的表情包 部分妖化（对自身要求能力控制不佳）",
        "identity": "core_member",
        "register_time": 1771819566
      }
    }
  },
